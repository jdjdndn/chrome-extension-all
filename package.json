{
  "name": "chrome-extension-template",
  "version": "1.0.0",
  "description": "Chrome 扩展 - 减少资源使用",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.js",
    "watch": "vite build --watch",
    "build": "vite build",
    "sync": "node scripts/watch-and-sync.js --once",
    "bundle": "node scripts/build-site-bundles.js",
    "bundle:watch": "node scripts/build-site-bundles.js --watch",
    "clean": "node scripts/watch-and-sync.js --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --ignore-pattern dist",
    "lint:fix": "eslint . --ignore-pattern dist --fix",
    "lint:dataset": "node scripts/check-dataset-selectors.js"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.1",
    "jsdom": "^29.0.2",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.4",
    "ws": "^8.20.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged && npm run typecheck && npm run lint:dataset"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
