{
  "name": "chrome-extension-template",
  "version": "1.0.0",
  "description": "Chrome 扩展 - 减少资源使用",
  "private": true,
  "scripts": {
    "bundle": "node scripts/build-site-bundles.js",
    "bundle:watch": "node scripts/build-site-bundles.js --watch",
    "clean": "node scripts/watch-and-sync.js --clean",
    "build": "node scripts/watch-and-sync.js --clean",
    "sync": "node scripts/watch-and-sync.js --once",
    "watch": "node scripts/watch-and-sync.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
