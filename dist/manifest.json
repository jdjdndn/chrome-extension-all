{
  "manifest_version": 3,
  "name": "减少资源使用",
  "version": "1.0.0",
  "description": "减少接口信息使用",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "cookies",
    "browsingData",
    "bookmarks",
    "history",
    "notifications",
    "contextMenus",
    "downloads"
  ],
  "host_permissions": ["*://*/*", "http://localhost/*", "http://127.0.0.1/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "event-bus-v4.6.js",
        "content/utils/logger.js",
        "content/core/script-loader.js",
        "content/eventbus-integration.js",
        "content/utils/storage.js",
        "content/utils/storage-bridge.js",
        "content/utils/dom.js",
        "content/utils/messaging.js",
        "content/core/store.js",
        "content/core/services.js",
        "content/core/pipeline.js",
        "content/core/site-base.js",
        "content/core/site-factory.js",
        "content/core/plugin-system.js",
        "content/core/config-manager.js",
        "content/core/selector-merger.js",
        "content/core/keyword-manager.js",
        "content/core/rule-manager.js",
        "content/core/lazy-loader.js",
        "content/core/cache-manager.js",
        "content/core/batch.js",
        "content/core/history-manager.js",
        "content/core/rule-conflict.js",
        "content/core/debug-panel.js",
        "content/core/input-validator.js",
        "content/core/security-manager.js",
        "content/core/config-migrator.js",
        "content/core/extension-api.js",
        "content/core/module-manager.js",
        "content/core/lazy-init-manager.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/common/script-switch.js",
        "content/common/redirect-links.js",
        "content/common/text-to-link.js",
        "content/common/link-blank.js",
        "content/common/add-title.js",
        "content/common/panel-position-manager.js",
        "content/common/doc-generator.js",
        "content/common/text-collector.js",
        "content/common/keyboard-pagination.js",
        "content.js"
      ],
      "css": ["styles.css"]
    },
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": ["content/bili.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": ["content/eventbus-integration.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.douyin.com/*"],
      "js": ["content/utils/localServer.js", "content/douyin.js"]
    },
    {
      "matches": ["*://*.douyin.com/*"],
      "js": ["content/eventbus-integration.js", "content/eventbus-integration-douyin.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.4hu.tv/*"],
      "js": ["content/4hu.js"]
    },
    {
      "matches": ["*://*.4hu.tv/*"],
      "js": ["content/eventbus-integration.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.weread.qq.com/*"],
      "js": ["content/weread.js"]
    },
    {
      "matches": ["*://*.weread.qq.com/*"],
      "js": ["content/eventbus-integration.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.quark.cn/*"],
      "js": ["content/quark.js"]
    },
    {
      "matches": ["*://*.quark.cn/*"],
      "js": ["content/eventbus-integration.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.18comic.vip/*"],
      "js": ["content/comic18.js"]
    },
    {
      "matches": ["*://*.18comic.vip/*"],
      "js": ["content/eventbus-integration.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.aliyundrive.com/*"],
      "js": ["content/aliyun.js"]
    },
    {
      "matches": ["*://*.aliyundrive.com/*"],
      "js": ["content/eventbus-integration.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.baidu.com/*"],
      "js": ["content/baiduPan.js"]
    },
    {
      "matches": ["*://*.baidu.com/*"],
      "js": ["content/eventbus-integration.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.zhipin.com/*"],
      "js": ["content/boss.js"]
    },
    {
      "matches": ["*://*.zhipin.com/*"],
      "js": ["content/eventbus-integration.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.xiaohongshu.com/*"],
      "js": ["content/xiaohongshu.js"]
    },
    {
      "matches": ["*://*.xiaohongshu.com/*"],
      "js": ["content/eventbus-integration.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.wyaqpx.com/*"],
      "js": ["content/dianGong.js"]
    },
    {
      "matches": ["*://*.wyaqpx.com/*"],
      "js": ["content/eventbus-integration.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.ymmfa.com/*"],
      "js": ["content/gongkong.js"]
    },
    {
      "matches": ["*://*.ymmfa.com/*"],
      "js": ["content/eventbus-integration.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/base/SiteScript.js", "content/youtube.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://github.com/*", "*://*.github.com/*"],
      "js": ["content/github.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://modelscope.cn/models*", "*://*.modelscope.cn/models*"],
      "js": ["content/modelscope.js"]
    },
    {
      "matches": ["*://modelscope.cn/*", "*://*.modelscope.cn/*"],
      "js": ["content/eventbus-integration.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js",
        "content/*.js",
        "content/common/*.js",
        "content/modules/*.js",
        "content/modules/SelectorEngine.js",
        "content/modules/Highlighter.js",
        "content/modules/VirtualList.js",
        "content/modules/StorageManager.js",
        "content/modules/SmartRecommender.js",
        "content/modules/DOMWatcher.js",
        "content/modules/SelectorWorker.js",
        "content/modules/IncrementalUpdater.js",
        "content/modules/SelectorPathVisualizer.js",
        "content/modules/OptimizationAdvisor.js",
        "content/modules/index.js",
        "content/devtools/*.js",
        "shared/*.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "devtools_page": "devtools/devtools.html"
}
